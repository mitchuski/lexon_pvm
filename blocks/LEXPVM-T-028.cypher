MERGE (c:LexContract {census: "LEXPVM-T-028", name: "Separation Theorem", cites: "glossary-master-v4 § ### Separation Theorem"})
MERGE (:Person {name: "First Person", contract: "Separation Theorem"})
MERGE (:Person {name: "Swordsman", contract: "Separation Theorem"})
MERGE (:Person {name: "Mage", contract: "Separation Theorem"})
MERGE (:Person {name: "Adversary", contract: "Separation Theorem"})
MERGE (:Contract {name: "Theorem", contract: "Separation Theorem"})
MERGE (:Amount {name: "Swordsman Leakage", contract: "Separation Theorem"})
MERGE (:Amount {name: "Mage Leakage", contract: "Separation Theorem"})
MERGE (:Amount {name: "Total Leakage", contract: "Separation Theorem"})
