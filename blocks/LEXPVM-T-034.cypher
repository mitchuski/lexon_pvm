MATCH (a {name: "Operator"}), (b {name: "Operator"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Enclave"}]->(b)
MATCH (a {name: "Operator"}), (b {name: "Operator"}) CREATE (a)-[:MAY_FILE {clause: "Seal", object: "Workload"}]->(b)
MATCH (a {name: "Enclave"}), (b {name: "Enclave"}) CREATE (a)-[:MAY_FILE {clause: "Measure", object: "Measurement"}]->(b)
