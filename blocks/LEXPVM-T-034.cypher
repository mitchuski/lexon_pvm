MERGE (c:LexContract {census: "LEXPVM-T-034", name: "Trusted Execution Environment (TEE)", cites: "glossary-master-v4 § ### Trusted Execution Environment (TEE)"})
MERGE (:Person {name: "Operator", contract: "Trusted Execution Environment (TEE)"})
MERGE (:Person {name: "Enclave", contract: "Trusted Execution Environment (TEE)"})
MERGE (:Person {name: "Verifier", contract: "Trusted Execution Environment (TEE)"})
MERGE (:Data {name: "Workload", contract: "Trusted Execution Environment (TEE)"})
MERGE (:Data {name: "Measurement", contract: "Trusted Execution Environment (TEE)"})
MERGE (:Text {name: "Result", contract: "Trusted Execution Environment (TEE)"})
