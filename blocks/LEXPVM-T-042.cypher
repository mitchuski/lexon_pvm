MERGE (c:LexContract {census: "LEXPVM-T-042", name: "Ceremony", cites: "glossary-master-v4 § ### Ceremony"})
MERGE (:Person {name: "First Agent", contract: "Ceremony"})
MERGE (:Person {name: "Second Agent", contract: "Ceremony"})
MERGE (:Person {name: "Witness", contract: "Ceremony"})
MERGE (:Text {name: "Understanding", contract: "Ceremony"})
