MATCH (a {name: "First Agent"}), (b {name: "First Agent"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Second Agent"}]->(b)
MATCH (a {name: "First Agent"}), (b {name: "First Agent"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Witness"}]->(b)
