MERGE (c:LexContract {census: "LEXPVM-T-128", name: "Betweenness Centrality", cites: "glossary-master-v4 § ### Betweenness Centrality"})
MERGE (:Person {name: "Source", contract: "Betweenness Centrality"})
MERGE (:Person {name: "Target", contract: "Betweenness Centrality"})
MERGE (:Person {name: "Gap", contract: "Betweenness Centrality"})
MERGE (:Contract {name: "Graph", contract: "Betweenness Centrality"})
MERGE (:Text {name: "Message", contract: "Betweenness Centrality"})
