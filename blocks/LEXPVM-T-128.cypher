MATCH (a {name: "Source"}), (b {name: "Source"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Gap"}]->(b)
MATCH (a {name: "Source"}), (b {name: "Source"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Target"}]->(b)
