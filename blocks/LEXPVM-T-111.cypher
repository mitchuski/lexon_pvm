MERGE (c:LexContract {census: "LEXPVM-T-111", name: "BRAID (V5)", cites: "glossary-master-v4 § ### BRAID (V5)"})
MERGE (:Person {name: "Generator", contract: "BRAID (V5)"})
MERGE (:Person {name: "Solver", contract: "BRAID (V5)"})
MERGE (:Number {name: "Compression Ratio", contract: "BRAID (V5)"})
MERGE (:Text {name: "Reasoning Graph", contract: "BRAID (V5)"})
