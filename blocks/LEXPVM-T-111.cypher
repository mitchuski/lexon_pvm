MATCH (a {name: "Generator"}), (b {name: "Generator"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Solver"}]->(b)
MATCH (a {name: "Generator"}), (b {name: "Generator"}) CREATE (a)-[:SET {clause: "recital", object: "Compression Ratio"}]->(b)
MATCH (a {name: "Generator"}), (b {name: "Generator"}) CREATE (a)-[:MAY_REGISTER {clause: "Plan Then Execute", object: "Reasoning Graph", condition: "this Frame is Compressed"}]->(b)
MATCH (a {name: "Generator"}), (b {name: "Solver"}) CREATE (a)-[:MAY_SEND {clause: "Plan Then Execute", object: "Reasoning Graph", condition: "this Frame is Compressed"}]->(b)
MATCH (a {name: "Solver"}), (b {name: "Solver"}) CREATE (a)-[:MAY_CERTIFY {clause: "Execute", object: "Reasoning Graph"}]->(b)
