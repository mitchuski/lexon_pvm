MATCH (a {name: "First Person"}), (b {name: "First Person"}) CREATE (a)-[:APPOINT {clause: "recital", object: "Scribe"}]->(b)
MATCH (a {name: "First Person"}), (b {name: "First Person"}) CREATE (a)-[:FIX {clause: "recital", object: "Continuation Act"}]->(b)
MATCH (a {name: "First Person"}), (b {name: "First Person"}) CREATE (a)-[:MAY_DECLARE {clause: "Answer Arc", object: "Arc Complete"}]->(b)
MATCH (a {name: "Scribe"}), (b {name: "Scribe"}) CREATE (a)-[:MAY_FIX {clause: "Mark Tide", object: "Close Time", condition: "Arc Complete is declared"}]->(b)
MATCH (a {name: "Scribe"}), (b {name: "Scribe"}) CREATE (a)-[:MAY_REGISTER {clause: "Continue Elsewhere", object: "Continuation Act", condition: "this Spellbook is Closed"}]->(b)
