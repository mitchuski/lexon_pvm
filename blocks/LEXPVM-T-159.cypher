MERGE (c:LexContract {census: "LEXPVM-T-159", name: "Spellbook Close", cites: "glossary-master-v4 § ### Spellbook Close"})
MERGE (:Person {name: "First Person", contract: "Spellbook Close"})
MERGE (:Person {name: "Scribe", contract: "Spellbook Close"})
MERGE (:Contract {name: "Spellbook", contract: "Spellbook Close"})
