MERGE (:Person {name: "Surveyor", contract: "Tetrahedral Sovereignty"})
MERGE (:Contract {name: "Tetrahedron", contract: "Tetrahedral Sovereignty"})
MERGE (:Amount {name: "Architectural Volume", contract: "Tetrahedral Sovereignty"})
MERGE (:Binary {name: "Protect Held", contract: "Tetrahedral Sovereignty"})
MERGE (:Binary {name: "Project Held", contract: "Tetrahedral Sovereignty"})
